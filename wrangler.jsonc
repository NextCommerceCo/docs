{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nextcommerce-docs",
  "compatibility_date": "2026-03-31",
  "assets": {
    "directory": "./out",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "docs.nextcommerce.com",
      "custom_domain": true
    }
  ]
}
